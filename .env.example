# Phoenix Cloud — from https://app.phoenix.arize.com (Settings → API Keys)
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/<your-space>

# Google AI Studio — from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. check_setup.py auto-selects a model with quota and writes this.
# GEMINI_MODEL=gemini-2.5-flash
# PHOENIX_PROJECT_NAME=gemini-hackathon
